@inject AppState AppState
@inject ToolSchemaService SchemaService
@inject NavigationManager Navigation
@implements IDisposable

<nav class="nav-menu">
    @if (AppState.IsDiscoveryMode)
    {
        <a href="/" class="nav-link nav-link-home">All Tools</a>
    }
    else
    {
        <a href="/" class="nav-link nav-link-home" @onclick="GoBackToAllTools" @onclick:preventDefault>All Tools</a>
    }

    @if (!string.IsNullOrEmpty(_filterText) || (_commands != null && _commands.Count > 10))
    {
        <div class="nav-search">
            <input type="text" placeholder="Filter commands..."
                   @bind="_filterText" @bind:event="oninput" />
        </div>
    }

    @if (_commands != null)
    {
        var filtered = GetFilteredCommands();
        var grouped = filtered
            .GroupBy(c => string.IsNullOrEmpty(c.Category) ? "General" : c.Category)
            .OrderBy(g => g.Key);

        @foreach (var group in grouped)
        {
            <div class="nav-category">
                <h4>@group.Key</h4>
                @foreach (var cmd in group.OrderBy(c => c.Name))
                {
                    <a href="@($"command/{cmd.Name}")" class="nav-link">
                        @cmd.Name
                    </a>
                }
            </div>
        }
    }
    else if (_isLoading)
    {
        <p class="nav-loading">Loading commands...</p>
    }
    else if (_error != null)
    {
        <p class="nav-error">@_error</p>
    }
</nav>

@code {
    private List<ToolCommandInfo>? _commands;
    private bool _isLoading;
    private string? _error;
    private string _filterText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnToolChanged += OnToolChanged;

        if (!AppState.IsDiscoveryMode)
        {
            await LoadCommands();
        }
    }

    private async void OnToolChanged()
    {
        await LoadCommands();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCommands()
    {
        if (string.IsNullOrEmpty(AppState.ToolName)) return;

        _isLoading = true;
        _error = null;

        try
        {
            _commands = await SchemaService.GetCommandSchemaAsync(AppState.ToolName);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private List<ToolCommandInfo> GetFilteredCommands()
    {
        if (_commands == null) return new();
        if (string.IsNullOrWhiteSpace(_filterText)) return _commands;

        return _commands
            .Where(c => c.Name.Contains(_filterText, StringComparison.OrdinalIgnoreCase)
                      || c.Description.Contains(_filterText, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void GoBackToAllTools()
    {
        AppState.ClearTool();
        Navigation.NavigateTo("/");
    }

    public void Dispose()
    {
        AppState.OnToolChanged -= OnToolChanged;
    }
}
