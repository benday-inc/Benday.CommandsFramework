@code {
    [Parameter] public ToolArgumentInfo Argument { get; set; } = default!;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private string DisplayLabel =>
        string.IsNullOrEmpty(Argument.FriendlyName) ? Argument.Name : Argument.FriendlyName;

    private bool IsRequiredField =>
        Argument.IsRequired && !Argument.AllowEmptyValue;

    private async Task OnInput(ChangeEventArgs e)
    {
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }

    private async Task OnBooleanChange(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        await ValueChanged.InvokeAsync(isChecked ? "true" : "false");
    }
}

<div class="form-field @(IsRequiredField ? "required" : "")">
    <label for="@Argument.Name">
        @DisplayLabel
        @if (IsRequiredField)
        {
            <span class="required-marker">*</span>
        }
    </label>

    @if (Argument.AllowedValues is { Length: > 0 })
    {
        <select id="@Argument.Name"
                value="@Value"
                @onchange="OnInput">
            @if (!IsRequiredField)
            {
                <option value="">-- select --</option>
            }
            @foreach (var option in Argument.AllowedValues)
            {
                <option value="@option" selected="@(option == Value)">@option</option>
            }
        </select>
    }
    else
    {
        @switch (Argument.DataType)
        {
            case "Boolean":
                <div class="checkbox-wrapper">
                    <input type="checkbox"
                           id="@Argument.Name"
                           checked="@(Value == "true")"
                           @onchange="OnBooleanChange" />
                </div>
                break;

            case "Int32":
                <input type="number"
                       id="@Argument.Name"
                       value="@Value"
                       @oninput="OnInput"
                       placeholder="@Argument.Description" />
                break;

            case "DateTime":
                <input type="date"
                       id="@Argument.Name"
                       value="@Value"
                       @onchange="OnInput" />
                break;

            default:
                <input type="text"
                       id="@Argument.Name"
                       value="@Value"
                       @oninput="OnInput"
                       placeholder="@Argument.Description" />
                break;
        }
    }

    @if (!string.IsNullOrEmpty(Argument.Description))
    {
        <small class="field-help">@Argument.Description</small>
    }
</div>
