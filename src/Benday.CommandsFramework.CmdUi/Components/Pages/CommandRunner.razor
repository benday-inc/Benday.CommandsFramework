@page "/command/{CommandName}"
@inject AppState AppState
@inject ToolSchemaService SchemaService
@inject CommandExecutionService ExecutionService

<h1>@_command?.Name</h1>
@if (_command != null)
{
    <p class="command-description">@_command.Description</p>

    <form @onsubmit="ExecuteCommand">
        <fieldset disabled="@_isExecuting">
            @foreach (var arg in _command.Arguments)
            {
                <ArgumentField Argument="arg"
                               Value="@GetValue(arg.Name)"
                               ValueChanged="@((string val) => SetValue(arg.Name, val))" />
            }
        </fieldset>

        <div class="form-actions">
            <button type="submit" class="btn-execute" disabled="@_isExecuting">
                @(_isExecuting ? "Executing..." : "Execute")
            </button>
            <button type="button" class="btn-clear" @onclick="ClearForm">Clear</button>
        </div>
    </form>

    @if (_validationErrors.Count > 0)
    {
        <div class="validation-errors">
            <h3>Missing Required Arguments</h3>
            @foreach (var error in _validationErrors)
            {
                <p class="error">@error</p>
            }
        </div>
    }

    @if (_result != null)
    {
        <CommandOutput Result="_result" />
    }
}
else if (_isLoading)
{
    <p>Loading command...</p>
}
else if (_error != null)
{
    <p class="error">@_error</p>
}

@code {
    [Parameter] public string CommandName { get; set; } = string.Empty;

    private ToolCommandInfo? _command;
    private Dictionary<string, string> _values = new();
    private List<string> _validationErrors = new();
    private CommandExecutionResult? _result;
    private bool _isExecuting;
    private bool _isLoading;
    private string? _error;

    private List<ToolCommandInfo>? _allCommands;

    protected override async Task OnParametersSetAsync()
    {
        _result = null;
        _validationErrors.Clear();
        _error = null;

        if (string.IsNullOrEmpty(AppState.ToolName)) return;

        _isLoading = true;
        try
        {
            _allCommands ??= await SchemaService.GetCommandSchemaAsync(AppState.ToolName);
            _command = _allCommands.FirstOrDefault(
                c => c.Name.Equals(CommandName, StringComparison.OrdinalIgnoreCase));

            if (_command == null)
            {
                _error = $"Command '{CommandName}' not found.";
            }
            else
            {
                // Initialize values with defaults
                _values = new Dictionary<string, string>();
                foreach (var arg in _command.Arguments)
                {
                    _values[arg.Name] = arg.Value ?? string.Empty;
                }
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetValue(string name) =>
        _values.TryGetValue(name, out var val) ? val : string.Empty;

    private void SetValue(string name, string value) =>
        _values[name] = value;

    private async Task ExecuteCommand()
    {
        if (_command == null || string.IsNullOrEmpty(AppState.ToolName)) return;

        // Validate required fields
        _validationErrors.Clear();
        foreach (var arg in _command.Arguments)
        {
            if (arg.IsRequired && !arg.AllowEmptyValue)
            {
                var val = GetValue(arg.Name);
                if (string.IsNullOrWhiteSpace(val))
                {
                    var label = string.IsNullOrEmpty(arg.FriendlyName) ? arg.Name : arg.FriendlyName;
                    _validationErrors.Add($"'{label}' is required.");
                }
            }
        }

        if (_validationErrors.Count > 0) return;

        _isExecuting = true;
        StateHasChanged();

        try
        {
            _result = await ExecutionService.ExecuteCommandAsync(
                AppState.ToolName,
                _command.Name,
                _command.Arguments,
                _values);
        }
        catch (Exception ex)
        {
            _result = new CommandExecutionResult
            {
                StandardError = ex.Message,
                ExitCode = -1,
                CommandLine = $"{AppState.ToolName} {_command.Name} ...",
                ExecutedAt = DateTime.Now
            };
        }
        finally
        {
            _isExecuting = false;
        }
    }

    private void ClearForm()
    {
        if (_command == null) return;

        _values.Clear();
        foreach (var arg in _command.Arguments)
        {
            _values[arg.Name] = string.Empty;
        }
        _validationErrors.Clear();
        _result = null;
    }
}
